*~

# Analysis outputs — main.py regenerates them; never commit
analyses/*/scratch/
analyses/*/report.md
analyses/*/summary.json
analyses/*/*.csv
!analyses/_template/

figures/exploration/
*.tmp

# Local credentials / env
.env
.env.local

# Private team-handle → pseudonym mapping. Never committed.
data/team_pseudonyms.csv

# Private raw submissions form export — has author_name, votes, comments etc.
# The sanitized public version lives next to it (without `.private`).
data/raw/submissions/*.private.csv

# data/grand_metrics.csv is a derived artifact regenerated by
# `mise run build:grand`. Its columns are also folded into designs.csv,
# which is the canonical single source of truth.
data/grand_metrics.csv

# LaTeX intermediates
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.toc
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls
